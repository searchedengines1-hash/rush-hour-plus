ck></statement></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement><statement name="ELSE"><block type="music_stop_all_sounds" id="acBDgu}p]$gXwzT/O3N%"><next><block type="music_playable_play" id="2jsgrh;mB0,O]bb,]d@S"><field name="playbackMode">music.PlaybackMode.InBackground</field><value name="toPlay"><shadow type="music_melody_playable" id="V~-2YJ=#u8(V4938GQ/S"><field name="melody">music.baDing</field></shadow><block type="music_song_field_editor" id="J~ot*Op[QO^4x;T)B:5A"><field name="song">assets.song`discordance`</field><data>{"commentRefs":[],"fieldData":{"song":"mySongs.song23"}}</data></block></value><next><block type="game_show_long_text" id="md`vLQU.(-_a1vySO3X$"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=")L+o)2#[qJ,XaN{2=jeh"><field name="TEXT">hey, I know you don't know me.</field></shadow></value><next><block type="game_show_long_text" id="A8}V#Xoa!Hi.[#t;9Gjt"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="*Aygrdue7zB94FU=~-XW"><field name="TEXT">you probably never will.</field></shadow></value><next><block type="game_show_long_text" id="Fb2Abm;C,a|ol)g45kf_"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="mOu,3I^DL{%bt7t$|#ij"><field name="TEXT">but you can't trust beta fein.</field></shadow></value><next><block type="game_show_long_text" id="v:pAd,74PN(}kpor;)ZC"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="Iu=m^GHX5A5Nf~Xd#r#w"><field name="TEXT">he is the reason the monsters are here.</field></shadow></value><next><block type="game_show_long_text" id="eL#;S0tw%!oe(;xHYV)^"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="AzH}p1G1X2@u$XRgcs2f"><field name="TEXT">not in the sense that the monsters spawned in his basement over time,</field></shadow></value><next><block type="game_show_long_text" id="%VZLqa-gGs1Bm0LymM4r"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="U`]pl,3YX8W/)l,]41)x"><field name="TEXT">but... nevermind.</field></shadow></value><next><block type="game_show_long_text" id="aqhy3:8JU)T=3zF3.]iI"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="e{H2zqcay[U7wNpnU]nn"><field name="TEXT">these monsters are something else.</field></shadow></value><next><block type="game_show_long_text" id="d{ONVINQ@6q#4qOc[Gp$"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="qWB)2Og6J#}y!A`xH5}k"><field name="TEXT">i can't tell you yet though.</field></shadow></value><next><block type="game_show_long_text" id="q*Vq+lC3EPV_z.3u;v:K"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=":V;g,_C(h3HLMB8aWW7+"><field name="TEXT">now, i must leave.</field></shadow></value><next><block type="spritesaytext" id="Yo?%bVQ9SiNh,m0Y(43#"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="this"><block type="variables_get" id="37^()Ml#3/R3=^E|41d."><field name="VAR" id="ReNI44MWR@BD_RuMcg:H">spritenew</field></block></value><value name="text"><shadow type="text" id="X6=7BE,|[*EEz^:cM``L"><field name="TEXT">Good Luck.</field></shadow></value><next><block type="spritedestroy2" id=")H?*=pKbB7!0R(aH--v:"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><field name="effect">effects.spray</field><value name="sprite"><block type="variables_get" id="%jrDu=-V=#EmxIp+X{wW"><field name="VAR" id="ReNI44MWR@BD_RuMcg:H">spritenew</field></block></value><next><block type="music_stop_all_sounds" id="6=?)|^e_}2a@#U.*XFSE"><next><block type="device_pause" id="l+TxKSUUzAqk-xbB^8$i"><value name="pause"><shadow type="timePicker" id="Yli){F3K$NI#ETnLK2}D"><field name="ms">1000</field></shadow></va