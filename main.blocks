</value><value name="kind"><shadow type="spritekind" id="}7Rp~GC3j]a-lWh5Zl+l"><field name="MEMBER">beta</field></shadow></value><value name="HANDLER_DRAG_PARAM_otherSprite"><block type="argument_reporter_custom" id="4F-QkS3YEG3wW5l0~:mm" deletable="false"><mutation typename="Sprite"></mutation><field name="VALUE">otherSprite5</field></block></value><value name="otherKind"><shadow type="spritekind" id="A0avD-=E{yH=#=lLYDME"><field name="MEMBER">Player</field></shadow></value><statement name="HANDLER"><block type="music_stop_all_sounds" id="CrNm/q9yJIFSY:S-U(?n"><next><block type="music_playable_play" id="cG@]ef)y:mV.(zU?w.#G"><field name="playbackMode">music.PlaybackMode.InBackground</field><value name="toPlay"><shadow type="music_melody_playable" id="u8;WX_|K*ecs50NnP*eE"><field name="melody">music.baDing</field></shadow><block type="music_song_field_editor" id="7p@s7UWTUwp5mT2U.zS9"><field name="song">assets.song`beta fein`</field><data>{"commentRefs":[],"fieldData":{"song":"mySongs.song8"}}</data></block></value><next><block type="game_show_long_text" id="O%Iyemlc[wdCa;|y}o}w"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="Dlppz/-G.%G,|(:Ff0~i"><field name="TEXT">hey its me, beta fein</field></shadow></value><next><block type="game_show_long_text" id="GH1wcZ*u:4_47F3n!J!R"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="oGkc(Uh|T[DMWI|O+c^i"><field name="TEXT">now, I HOPE you read the controls at the beginning, and yes you can spawn lights with space bar</field></shadow></value><next><block type="game_show_long_text" id="Oug:u9z*[R,i,-e|?Q|z"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=")_JpDNP#V/8ff5@L4/rM"><field name="TEXT">look, some enemies target you, the light, or more behaviors</field></shadow></value><next><block type="game_show_long_text" id="%9;K9W:+rD%fr@07J;V."><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="o!gjxdq26tS-3IyPIPY/"><field name="TEXT">now there's one consistent thing, all traps kill all enemies</field></shadow></value><next><block type="game_show_long_text" id="Q3dB,]m%~cL7OkvYj3G$"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="^J_BxWe+5%}X6Dz8=zRK"><field name="TEXT">also you need 5 lights to spawn a trap</field></shadow></value><next><block type="game_show_long_text" id="3s!4XLJ24=H,{mVh~g#1"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="+fo$-:VoY@$c@v.g]D-@"><field name="TEXT">DO NOT PLACE A LIGHT ON A TRAP, YOU ARE WASTING OUR VALUABLE INVESTORS MONEY!!!!!!!!!!!!!</field></shadow></value><next><block type="game_show_long_text" id="?Mxz!jUN?gRUY_YR^xt8"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="t|ow*n5`GC5j(Nd)fi@{"><field name="TEXT">remember now, you will rage a lot... hey wait am i breaking the 4th wall.</field></shadow></value><next><block type="game_show_long_text" id="HjdGKJ{=a]q.?TXI`}R)"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="(9:(xnW[:*m4#_Vm^sTK"><field name="TEXT">wait let me get my script!</field></shadow></value><next><block type="game_show_long_text" id="aKOsclT)h0-Jj;QZ)1LL"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="-=,E4``8W4Q6@F#{go-o"><field name="TEXT">"Hello trapper! I hired you to take care of the monsters in my basement" (dont ask)</field></shadow></value><next><block type="game_show_long_text" id="|vY)_Ck]t,#$3t/91:|~"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="VLQ0.b(I5x2LM%lW$(`i"><field name="TEXT">"ill pay you well"</field></shadow></value><next><block type="game_show_long_text" id="ahAb#]VzFVHoIVsqlrb!"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="QZuh4I;!#+xzfKHO55|D"><field name="TEXT">"here's how to get to the cave: go straight, and go left.</field></shadow></value><next><block type="game_show_long_text" id="ght2VrpChW0f:,uz5/V]"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="@mX`Y_da82VS)g0j1,Go"><field name="TEXT">"And then turn left to get to the first level"</field></shadow></value><next><block type="game_show_long_text" id="](ZAQ1:wq{EIL{?09Ygb"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="G0s/|NH[(F9SRL?KCSq/"><field name="TEXT">"By the way, you have limited time."</field></shadow></value><next><block type="music_stop_all_sounds" id="$KQf1S7723rd}iwTTao}"><next><block type="device_pause" id="^;UbUnY4!Vdd4t*%W:;|"><value name="pause"><shadow type="timePicker" id="52=Eqkjq-0Xy5]76]u?h"><field name="ms">1000</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block><block type="spritesoverlap" id="xlUy:dd75)]fClCm_(-K" x="0" y="16964"><value name="HANDLER_DRAG_PARAM_sprite"><block type="argument_reporter_custom" id="bRK5eL4OjL6CS.d3]Nh:" deletable="false"><mutation typename="Sprite"></mutation><field name="VALUE">sprite6</field></block></value><value name="kind"><shadow type="spritekind" id="EdSPT~0ls%UdZayg6WX]"><field name="MEMBER">Enemy</field></shadow></value><value name="HANDLER_DRAG_PARAM_otherSprite"><block type="argument_reporter_custom" id="|Zjm)Rg+-_m+0.`r`t)5" deletable="false"><mutation typename="Sprite"></mutation><field name="VALUE">otherSprite2</field></block></value><value name="otherKind"><shadow type="spritekind" id="u3@.yrNA3;c0Zu-RgR[5"><field name="MEMBER">Projectile</field></shadow></value><statement name="HANDLER"><block type="controls_if" id="elZljAmJ(ddYRJ-So@~|"><value name="IF0"><shadow type