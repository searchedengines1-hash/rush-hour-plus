ean" id="Gw^m$q*I^aC61lZ7uh73"><field name="BOOL">TRUE</field></block></value><next><block type="music_playable_play" id="W#8gf0x#D.v6mJiV{2Au"><field name="playbackMode">music.PlaybackMode.LoopingInBackground</field><value name="toPlay"><shadow type="music_melody_playable" id="7$qT}*HqNVFx-i8MnIg2"><field name="melody">music.baDing</field></shadow><block type="music_song_field_editor" id="Q;GU,s%waqVEiuMb#(Q_"><field name="song">hex`
                
                `</field><data>{"commentRefs":[],"fieldData":{"song":null}}</data></block></value><next><block type="game_show_long_text" id="C|a1pTHft5u!kZ7XK8jP"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="bz4F1Ha7dVt5:^n2m[@i"><field name="TEXT">Hello.</field></shadow></value><next><block type="game_show_long_text" id="Kg?qGCLzYs/Z.keQ6bC+"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="WhbGQ:@L^2P,H1fQ_vzp"><field name="TEXT">you've done it.</field></shadow></value><next><block type="game_show_long_text" id="OS]4TQ^EzxPivH#7[ZJG"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="*yAXfQ,Wr|{;93WqXq:L"><field name="TEXT">Now... i believe we can talk uninterrupted.</field></shadow></value><next><block type="controls_repeat_ext" id="@kI_i)qmg9vs5kv[,Uno"><value name="TIMES"><shadow type="math_whole_number" id="{5Ti2xDjFQ_fdSq7RJue"><field name="NUM">5</field></shadow></value><statement name="DO"><block type="arcade_story_show_player_choices" id="mf|6=;~ATY-JhPw0v+/5"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="3" _input_init="true"></mutation><value name="choice1"><shadow type="text" id="A,L%cehgDhBLR6C|h[:g"><field name="TEXT">The Monsters</field></shadow></value><value name="choice2"><shadow type="text" id="QoCs2m#UOQdeLo0Z!Kq="><field name="TEXT">The Slime</field></shadow></value><value name="choice3"><shadow type="text" id="@a7c{1CQ$:KL#.g=W1%O"><field name="TEXT">Being Chased </field></shadow></value><value name="choice4"><shadow type="text" id="PllfU}y`qmInH1%4uP4s"><field name="TEXT">You</field></shadow></value><value name="choice5"><shadow type="text" id="u$`J%`Z1Uqar^9F)@lyM"><field name="TEXT">Family</field></shadow></value><next><block type="controls_if" id="1E:(viCS6Sk0v5:7}CKU"><mutation elseif="4"></mutation><value name="IF0"><shadow type="logic_boolean" id=".DlJ@#`SZ3va%p7/.j2Q"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="%.ldXam`MQTgeAntq=fy"><value name="choice"><shadow type="text" id="O:+UWOM@STek~k=x1K{V"><field name="TEXT">The Monsters</field></shadow></value></block></value><statement name="DO0"><block type="game_show_long_text" id="r:;Iox_Zx2x-H$;Gtc~/"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="0pU:Fc;YK_2n/zuVytMR"><field name="TEXT">The monsters are simply previous adventurers that were changed.</field></shadow></value><next><block type="game_show_long_text" id="Z@O3q/9Q#%kDO?f_|N?E"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="w1DnhL0CYgZIvAaGZa|P"><field name="TEXT">I'd presume the slime killed them himself and transformed them.</field></shadow></value><next><block type="game_show_long_text" id="f`2`7YJKR;A:~o/OT,MG"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="@(T/O7;!Iv:]w1q}:pPy"><field name="TEXT">They never truly die, though. So you didn't murder them.</field></shadow></value><next><block type="game_show_long_text" id="tpX^hDu:P^I(RY/j@uS#"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="b9Ig:,f|qc,37XTfI8{L"><field name="TEXT">The one with the eye used light magic, so maybe they're drawn to what they used to harness.</field></shadow></value><next><block type="game_show_long_text" id="fv5!R!mcBJ~5@zF_|m+{"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="=rqVnGss:]RXFob5?y:l"><field name="TEXT">I don't know about the rest though.</field></shadow></value><next><block type="game_show_long_text" id="1O:@B-AJaK}{_=v5ZCT_"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="?C4m`Hak[6B|ZWKqXC^s"><field name="TEXT">Also. the reason i know what happened to her is because...</field></shadow></value><next><block type="spritesetimage" id="$)/!*Pk73dRvV(JOIH~^"><value name="sprite"><block type="variables_get" id="O[=f5H*(m8-!nI~h;3;g"><field name="VAR" id="ReNI44MWR@BD_RuMcg:H">spritenew</field></block></value><value name="img"><shadow type="screen_image_picker" id="*??~j0_J`DV9Mf8l;WhN"><field name="img">assets.image`talkinghatblush`</field><data>{"commentRefs":[],"fieldData":{"img":"myImages.image8"}}</data></shadow></value><next><block type="game_show_long_text" id="F9%{?ot2:Z(,/0nl5|!4"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="TleVx?%KXFZ%sAs5%f(`"><field name="TEXT">she was... uh.</field></shadow></value><next><block type="game_show_long_text" id="k3gvnlBfiv!B[FsaTe`*"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="J:}HNH~_A*52;v)f]):t"><field name="TEXT">she was my...</field></shadow></value><next><block type="game_show_long_text" id="7ras~,E;:agd$}Z5acRf"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="-[Mt1O@K96D^9goSR*i+"><field name="TEXT">nevermind.</field></shadow></value><next><block type="spritesetimage" id="$O#+9Ispj0vCqTx4=9X5"><value name="sprite"><block type="variables_get" id="mTY*#*(V8*ea]/!KpeMb"><field name="VAR" id="ReNI44MWR@BD_RuMcg:H">spritenew</field></block></value><value name="img"><shadow type="screen_image_picker" id="|BDu(J%8e`oq~w1ZN{6%"><field name="img">assets.image`talkinghat`</field><data>{"commentRefs":[],"fieldData":{"img":"myImages.image2"}}</data></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement><value name="IF1"><shadow type="logic_boolean" id="mcqLt*I-#[(G)#(ZI^Nk"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="3!A%Pl:{5{jt?QP,w*X="><value name="choice"><shadow type="text" id="l|eL7Y.qscMjt:v[uVSB"><field name="TEXT">The Slime</field></shadow></value></block></value><statement name="DO1"><block type="game_show_long_text" id="eR/)cjuJY)VXA5k9VoEk"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="/0;1CA(E=U**Pa]*o3~d"><field name="TEXT">That slime has already left.</field></shadow></value><next><block type="game_show_long_text" id="nTnJDFO}i5MuK_BLcj%H"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="5i0]nLk~*V2,}AmZCdiT"><field name="TEXT">You weren't meant to survive, after all.</field></shadow></value><next><block type="game_show_long_text" id="bo|6bU@k|4!0%(6ksYkn"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="~z-r{E/d;Yp`4gZWQ$Z1"><field name="TEXT">He and I once were friends.</field></shadow></value><next><block type="game_show_long_text" id="Wst|g/Ehf~uMfJnjwIqy"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="WGf*C?%,DxQ6f``jT)+i"><field name="TEXT">I don't fully know what changed him, but I did try to stop him.</field></shadow></value><next><block type="game_show_long_text" id="c.q.TH-wx,HEG66,g2yD"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="rNKj%(YFEfo#LVL^ah5s"><field name="TEXT">He was my only Friend.</field></shadow></value></block></next></block></next></block></next></block></next></block></statement><value name="IF2"><shadow type="logic_boolean" id="S/;0@-`.h$)E5fd;toxW"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="Laz{STL|o9iA`p4n#SNS"><value name="choice"><shadow type="text" id="aF;ojgh]e{kuX-o+7Q%@"><field name="TEXT">Being Chased </field></shadow></value></block></value><statement name="DO2"><block type="game_show_long_text" id="t3h@|pLh=hveiY}*Wq1o"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="s(K)MxWC0C(.F}27Yw3R"><field name="TEXT">You mean that monster?</field></shadow></value><next><block type="game_show_long_text" id="U|`rF%uF:1bmj2y!/=L."><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="-@Z%`$_K9oHvFv@O29id"><field name="TEXT">i have no idea.</field></shadow></value><next><block type="game_show_long_text" id="AoL0a[vdGEe2Pv8:~:R]"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="$wB-pJ#,VWbE2[$]0xo."><field name="TEXT">though if we go on the notion that the monsters are souless...</field></shadow></value><next><block type="game_show_long_text" id="9r?^iG)F;`W3(~H~7K6s"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="7?hH!A%ZTdC`|d{M)]?v"><field name="TEXT">it could be a culmination of their emotions and spirits.</field></shadow></value></block></next></block></next></block></next></block></statement><value name="IF3"><shadow type="logic_boolean" id="Qk2+ztClx-4CI?Xh2#19"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="q{VN[oZtKshFb-P[t}_r"><value name="choice"><shadow type="text" id="h.DUBC6Jw8LLftCZCL%g"><field name="TEXT">You</field></shadow></value></block></value><statement name="DO3"><block type="game_show_long_text" id="Ds5h[a#dWO]vuJ@caX(s"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="1@0)IkrUiMn(I]sXoh;A"><field name="TEXT">I'm just a talking hat.</field></shadow></value><next><block type="game_show_long_text" id="@N-~CQom.Y/uzy$dei_q"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="}a=Uge8RCVUPvw}(=JwQ"><field name="TEXT">My name, if you want to know though, is Woodrow.</field></shadow></value><next><block type="game_show_long_text" id="KRsI}5%wIPLxiDKR;])l"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="t!fmzL#UcVp[%;kn)a#X"><field name="TEXT">About my powers...</field></shadow></value><next><block type="game_show_long_text" id="F|Q0=h0vF,0t~@00sa]Q"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=",Xt.V4~$Ndsy_R@DLs51"><field name="TEXT">I am not really that strong.</field></shadow></value><next><block type="game_show_long_text" id="QcsFj+~Z,L{hyFAkQmHg"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=":FJYlFdig9|IW#`J|%*r"><field name="TEXT">I didn't even make this place.</field></shadow></value><next><block type="game_show_long_text" id="djj%KBGM$a,uhs|C!oyj"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="2vGc?Oo_0VmY}H|SPliX"><field name="TEXT">I can go invisible though.</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></statement><value name="IF4"><shadow type="logic_boolean" id="w.GOQG=*6_K3~sjheu`+"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="pg)1xao,zQZHlNz/aZAR"><value name="choice"><shadow type="text" id="P~W.T/[~ocIv/H?;Nku5"><field name="TEXT">Family</field></shadow></value></block></value><statement name="DO4"><block type="game_show_long_text" id="E|tD0IYB!!6Hcs~l6XDJ"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="0Yj*3g_Sl6{!A|tO-GM]"><field name="TEXT">My... Family?</field></shadow></value><next><block type="game_show_long_text" id="w+3Xm@~%rsKuYGugc^PZ"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=":KbIp$u]sVPKu.8Ego~]"><field name="TEXT">Well... They're all hats.</field></shadow></value><next><block type="game_show_long_text" id="@krjOjYKTK2c]*7YEB0k"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=";2_55@QoorkpT8NCJd+Z"><field name="TEXT">Maybe one day you can meet them, but i don't think it's important right now.</field></shadow></value></block></next></block></next></block></statement></block></next></block></statement><next><block type="game_show_long_text" id="mJJ_kvc6,logY9Y%k.z%"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="Ap}z)6$juQA:~tgq=VtL"><field name="TEXT">Now... Was that all you wanted to hear?</field></shadow></value><next><block type="arcade_story_show_player_choices" id="8|,Dc{p4=Aj[eredBIG!"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="choice1"><shadow type="text" id="hS3@M*rH.u(G#[e)=:bM"><field name="TEXT">Yes</field></shadow></value><value name="choice2"><shadow type="text" id="02j./XLeXl]l^H-:*+2-"><field name="TEXT">No</field></shadow></value><next><block type="controls_if" id=".6q*T_w9P~.CaWwzP2z="><mutation elseif="1"></mutation><value name="IF0"><shadow type="logic_boolean" id="jpge9Jv3]tZ9rAaQ43nS"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="]Ep`zEOEii,VCJ[1z=XX"><value name="choice"><shadow type="text" id="b3Udlr*uc`/XxZqc;F!V"><field name="TEXT">Yes</field></shadow></value></block></value><statement name="DO0"><block type="game_show_long_text" id="H:f[=jqN/s.f8yZ66=RN"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="}uu/3OZ$Q}DfFVAj3|%Y"><field name="TEXT">Very Well.</field></shadow></value><next><block type="game_show_long_text" id="cKBiyquD@Z$JPFTkR:7!"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="phvsGV{umo:Iy1td(DsW"><field name="TEXT">You may go.</field></shadow></value><next><block type="game_setgameovereffect" id="w*Y_,1D+e7R^,CP=Cjh6"><field name="effect">effects.none</field><value name="win"><shadow type="toggleWinLose" id="BLX?EMX+S@0bAFTb8NfD"><field name="win">true</field></shadow></value><next><block type="game_setgameovermessage" id="qw{AS|@aBA,pDS{6*;Xu"><value name="message"><shadow type="text" id="G:_+nneX:@7%U0Ex_b,Y"><field name="TEXT">Finished.</field></shadow></value><value name="win"><shadow type="toggleWinLose" id="^P!ZuVaF;gCQ@jVnn.TJ"><field name="win">true</field></shadow></value><next><block type="gameOver2" id="92YuST8a9#dxWeeC00=|"><value name="win"><shadow type="toggleWinLose" id="/w|_6c5tVL[pr6Mf4og3"><field name="win">true</field></shadow></value></block></next></block></next></block></next></block></next></block></statement><value name="IF1"><shadow type="logic_boolean" id="%=ymO4g9q$]|lH]7%tf:"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="B7tIY:tWh(YxxlIlOj(~"><value name="choice"><shadow type="text" id="w}D-MbkwIE~)y9)Y?ysg"><field name="TEXT">No</field></shadow></value></block></value><statement name="DO1"><block type="spritesetimage" id="UO!jm}8wkalY7-WL~d-v"><value name="sprite"><block type="variables_get" id="IXw;CFq$p=(ZBZ]ZhAd9"><field name="VAR" id="ReNI44MWR@BD_RuMcg:H">spritenew</field></block></value><value name="img"><shadow type="screen_image_picker" id="18PH-?E.CU(nRY5KBr`D"><field name="img">assets.image`talkinghatuhm`</field><data>{"commentRefs":[],"fieldData":{"img":"myImages.image10"}}</data></shadow></value><next><block type="game_show_long_text" id="LSToRtoSd=x{K6r-5-7*"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="5{P~23FF4Y3xmQp!}Zng"><field name="TEXT">Well... uh..</field></shadow></value><next><block type="game_show_long_text" id="{a1LE6T%Gl/~W8nV1lmP"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="`EGAby~~kTZ|5um7^!i."><field name="TEXT">i dont know what you'd want now...</field></shadow></value><next><block type="game_show_long_text" id="4co80E-9,jJ|k#MXS_SO"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="ODCSCrhr*mj=hhI,;l_r"><field name="TEXT">but ask away! i guess.</field></shadow></value><next><block type="game_show_long_text" id="iey1bg~!4*584j2_axDE"><field name="layout">DialogLayout.Top</field><value name="str"><shadow type="text" id="M#W#!KNELZsOX,t?fYm["><field name="TEXT">(i wasn't prepared for this)</field></shadow></value><next><block type="arcade_story_show_player_choices" id="QJWv(9a%!eq_miRB6qZK"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="2" _input_init="true"></mutation><value name="choice1"><shadow type="text" id="K,;ewWCB`[1COgSL:,Fp"><field name="TEXT">Advice</field></shadow></value><value name="choice2"><shadow type="text" id="?!#T}nM[uN*xW^aHRUF1"><field name="TEXT">Hobbies</field></shadow></value><value name="choice3"><shadow type="text" id="),tdxys3-iEZl}HRc1TP"><field name="TEXT">Goodbye</field></shadow></value><value name="choice4"><shadow type="text" id="RIsFD9k!8@[OCUT:%br)"><field name="TEXT">Restart</field></shadow></value><next><block type="spritesetimage" id="m9zgtO};o9WP9,c#(!ym"><value name="sprite"><block type="variables_get" id="5D6crotSoNsX2,X/-83}"><field name="VAR" id="ReNI44MWR@BD_RuMcg:H">spritenew</field></block></value><value name="img"><shadow type="screen_image_picker" id="p39va;k~`e!mD8X,Q0qf"><field name="img">assets.image`talkinghat`</field><data>{"commentRefs":[],"fieldData":{"img":"myImages.image2"}}</data></shadow></value><next><block type="controls_if" id="E##[qv#N1[W4d6F!zb02"><mutation elseif="3"></mutation><value name="IF0"><shadow type="logic_boolean" id="X,bAZfQud!$|}rJy:yTG"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="[p*eu]YQ8QZUvvcv.-^v"><value name="choice"><shadow type="text" id="%38G`gBCMU(Yi-6K]Sg@"><field name="TEXT">Advice</field></shadow></value></block></value><statement name="DO0"><block type="game_show_long_text" id="aP%M}|s+`a|@}ys-XaY7"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="F~$J:32V$.Xm,ZAWXAu#"><field name="TEXT">I'd say...</field></shadow></value><next><block type="game_show_long_text" id="V+fi.^!sR~K-$H#Bw2r;"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="ykax|bflYsNcC@n0yF5~"><field name="TEXT">Spend time with those you love when you can.</field></shadow></value></block></next></block></statement><value name="IF1"><shadow type="logic_boolean" id="kmU4K!;^yGnFgyb]w~#o"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="U44_%K-vf#Eg+%Z+dHb@"><value name="choice"><shadow type="text" id="d[[m{oL(ihfv,{2Q?Rgs"><field name="TEXT">Hobbies</field></shadow></value></block></value><statement name="DO1"><block type="game_show_long_text" id="RITJE/2?(^X@@?C=E(ga"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="(%uPM}LM6o-z|=fpnb0_"><field name="TEXT">Well... I like to read, and Garden</field></shadow></value><next><block type="game_show_long_text" id="|~@o91L]lc*S#+6+?!RR"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="t`Z4cD$lR*KX,KM%;]Fi"><field name="TEXT">I can grab things without hands, which is how I do that!</field></shadow></value></block></next></block></statement><value name="IF2"><shadow type="logic_boolean" id="YTI,d+z=}kH5tnE,mcjT"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="Wm@0`4,=6KWj4^}%8d:|"><value name="choice"><shadow type="text" id="Tg6sci~=?h)%j-Hy.vQ?"><field name="TEXT">Goodbye.</field></shadow></value></block></value><statement name="DO2"><block type="spritesetimage" id="hae:HzcO!7S:$XJZ)/Sv"><value name="sprite"><block type="variables_get" id="m~YK_[+gdxL;^faA4%E!"><field name="VAR" id="`RY*W7K/$9E?]Be!5^dI">mySprite</field></block></value><value name="img"><shadow type="screen_image_picker" id="35%y|.4,o}[Gu@kvSwwi"><field name="img">assets.image`talkinghat0`</field><data>{"commentRefs":[],"fieldData":{"img":"myImages.image11"}}</data></shadow></value><next><block type="game_show_long_text" id="2Mnx2|.;,rs~t]@cF.DK"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="sKgQZ|Wdaz9Nj]l0:w?%"><field name="TEXT">Goodbye, Friend!</field></shadow></value><next><block type="game_show_long_text" id="J{614mQS:r({@b*DhBqe"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=":N7#Y8RVRl^|68!]^H(m"><field name="TEXT">You can always come back, so don't be shy!</field></shadow></value><next><block type="game_show_long_text" id="/FJ^x4qr0GLiqZ|8z]jX"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="v#=^[K-$P3-Fj*TTt$kP"><field name="TEXT">Just whisper my name.</field></shadow></value><next><block type="game_setgameovermessage" id="W+.(L6dKVM_lJAB4%^}7"><value name="message"><shadow type="text" id="B[O#L4/._a39{50R~8t~"><field name="TEXT">The True Ending.</field></shadow></value><value name="win"><shadow type="toggleWinLose" id="|hyNwSUWi$WHkaC3GJ-F"><field name="win">true</field></shadow></value><next><block type="gameOver2" id="sQqJ5hnUCJRFR8V+ZN%,"><value name="win"><shadow type="toggleWinLose" id="$J^Gwcn.-Jn_?]ZQ(xl`"><field name="win">true</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></statement><value name="IF3"><shadow type="logic_boolean" id="5Q6[3rt|D6?]ZVl,8Ubr"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="VdpkFU1#Xb/-/tfpI~_Z"><value name="choice"><shadow type="text" id="+YJUG^ujo;lTrd]YZ)H="><field name="TEXT">Restart</field></shadow></value></block></value><statement name="DO3"><block type="game_show_long_text" id=":I3bP1Z._UK6A,@:9[{L"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="T8LdHMo(7UdOb1^Mh.Qe"><field name="TEXT">You want me to send you back?</field></shadow></value><next><block type="game_show_long_text" id="oYt_{29gPf0`i6XGX$]r"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="+k#8~RSp^{+l]_2qyPL|"><field name="TEXT">I mean... I can do that... but why?</field></shadow></value><next><block type="game_show_long_text" id="Zh,zc7%(r3?1{=q{=GJz"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="[LU*wD.24]E@X-2qG;Jg"><field name="TEXT">...</field></shadow></value><next><block type="game_show_long_text" id="+UOEj_oRTmKfysI-JVT$"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="40p+-n6S%y|SZA_bKQHQ"><field name="TEXT">do you really want to?</field></shadow></value><next><block type="arcade_story_show_player_choices" id="6PQ#mUP$_[y;9J*hIjpG"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="choice1"><shadow type="text" id="tg?-{`OEc9d:=FO1;`d|"><field name="TEXT">I do.</field></shadow></value><value name="choice2"><shadow type="text" id="};8w~-*B#MGG;)BO=xpz"><field name="TEXT">I don't</field></shadow></value><next><block type="controls_if" id="~u*C6f:TEA6}5A5$GR=4"><mutation elseif="1"></mutation><value name="IF0"><shadow type="logic_boolean" id="JEb2hCex*%-_J%p`;UAY"><field name="BOOL">TRUE</field></shadow><block type="arcade_story_last_answer" id="m}bAXlIrfHayj+a6C~K$"><value name="choice"><shadow type="text" id="cN;n%Nc5ie,L_O~G#|1)"><field name="TEXT">I do.</field></shadow></value></block></value><statement name="DO0"><block type="variables_change" id="NMe1]ogVz/8r}oX8%-ix"><field name="VAR" id="*RU!^2[fHt/vszxa=+5|">True_Win</field><value name="VALUE"><shadow type="math_number" id="49ZR~e_mZHJOM0H1/D~x"><field name="NUM">-1</field></shadow></value><next><block type="game_setgameovermessage" id="-Uu[)w9MWZ1^2z0V}9z_"><value name="message"><shadow type="text" id="!5:F6JwQSq]=yauSjiHq"><field name="TEXT">You may feel a tingle...</field></shadow></value><value name="win"><shadow type="toggleWinLose" id="43LCrzWyLVxL!EY0cQWv"><field name="win">false</field></shadow></value><next><block type="game_setgameovereffect" id=":EC@7Rb5EOGj%jnupif6"><field name="effect">effects.dissolve</field><value name="win"><shadow type="toggleWinLose" id="h88CvGwQ(WHzV7f%G//-"><field name="win">true</field></shadow></value><next><block type="gameOver2" id="^TwxDQ%wskXEtU?LDNX7"><value name="